# Seaduced Experience - Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# DO NOT commit .env.local to version control.

# Google Apps Script Execution URL
# Used by api/proxy.js
GAS_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec"

# SumUp API Configuration
# Used by api/sumup.js
SUMUP_ACCESS_TOKEN="sup_sk_your_secret_key_here"
SUMUP_MERCHANT_CODE="YOUR_MERCHANT_CODE"

# Environment
NODE_ENV="development"
